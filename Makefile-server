# Makefile SEGURO para executar DENTRO do servidor alvo

.PHONY: help resetar configurar status

# Cores
RED := \033[0;31m
GREEN := \033[0;32m
YELLOW := \033[1;33m
NC := \033[0m

help: ## Exibir comandos disponíveis
	@echo "$(YELLOW)🎯 Makefile SEGURO do Servidor$(NC)"
	@echo "================================"
	@awk 'BEGIN {FS = ":.*?## "} /^[a-zA-Z_-]+:.*?## / {printf "  $(GREEN)%-12s$(NC) %s\n", $$1, $$2}' $(MAKEFILE_LIST)

resetar: ## Reset SEGURO - mantém conectividade
	@echo "$(RED)🔄 RESET SEGURO - MANTENDO CONECTIVIDADE$(NC)"
	@echo "============================================="
	@echo "[1] SSH vulnerável (sem quebrar conexão)..."
	@sudo bash -c 'cat > /etc/ssh/sshd_config << EOF\nPort 22\nPermitRootLogin yes\nPasswordAuthentication yes\nPermitEmptyPasswords no\nX11Forwarding yes\nUsePAM yes\nEOF' 2>/dev/null || echo "Config SSH aplicada"
	@echo "[2] Firewall OFF..."
	@sudo ufw --force disable 2>/dev/null || echo "Firewall já desabilitado"
	@echo "[3] Parando serviços..."
	@sudo systemctl stop fail2ban 2>/dev/null || true
	@sudo systemctl stop auditd 2>/dev/null || true
	@echo "[4] Limpando hardening..."
	@sudo rm -f /etc/audit/rules.d/security-hardening.rules 2>/dev/null || true
	@sudo rm -f /etc/fail2ban/jail.local 2>/dev/null || true
	@echo "[5] Usuário apolo..."
	@sudo useradd -m -s /bin/bash apolo 2>/dev/null || echo "Usuário já existe"
	@echo "apolo:123456789" | sudo chpasswd 2>/dev/null || echo "Senha já definida"
	@sudo usermod -aG sudo apolo 2>/dev/null || echo "Já no grupo sudo"
	@echo "$(GREEN)✅ RESET SEGURO CONCLUÍDO - CONECTIVIDADE PRESERVADA!$(NC)"

configurar: ## Configuração inicial SEGURA
	@echo "$(YELLOW)🔧 CONFIGURAÇÃO INICIAL SEGURA$(NC)"
	@echo "=================================="
	@echo "[1] Verificando SSH..."
	@sudo systemctl start ssh 2>/dev/null || echo "SSH já ativo"
	@sudo systemctl enable ssh 2>/dev/null || echo "SSH já habilitado"
	@echo "[2] Backup SSH config..."
	@sudo cp /etc/ssh/sshd_config /etc/ssh/sshd_config.backup 2>/dev/null || echo "Backup já existe"
	@echo "[3] SSH vulnerável..."
	@sudo bash -c 'cat > /etc/ssh/sshd_config << EOF\nPort 22\nPermitRootLogin yes\nPasswordAuthentication yes\nPermitEmptyPasswords no\nX11Forwarding yes\nUsePAM yes\nEOF'
	@echo "[4] Firewall OFF..."
	@sudo ufw --force disable 2>/dev/null || true
	@echo "[5] Usuário apolo..."
	@sudo useradd -m -s /bin/bash apolo 2>/dev/null || echo "Usuário já existe"
	@echo "apolo:123456789" | sudo chpasswd
	@sudo usermod -aG sudo apolo
	@echo "$(GREEN)✅ CONFIGURAÇÃO SEGURA CONCLUÍDA!$(NC)"

status: ## Verificar status atual
	@echo "$(YELLOW)📊 STATUS ATUAL DO SERVIDOR$(NC)"
	@echo "==============================="
	@echo "SSH:"
	@sudo systemctl is-active ssh 2>/dev/null && echo "  ✅ Ativo" || echo "  ❌ Inativo"
	@echo "Firewall:"
	@sudo ufw status 2>/dev/null | head -1 || echo "  ✅ Desabilitado"
	@echo "Usuário apolo:"
	@id apolo 2>/dev/null && echo "  ✅ Existe" || echo "  ❌ Não existe"
	@echo "Conectividade:"
	@ping -c 1 8.8.8.8 >/dev/null 2>&1 && echo "  ✅ Internet OK" || echo "  ⚠️ Sem internet"

limpar: ## Limpeza total (cuidado!)
	@echo "$(RED)🧹 LIMPEZA TOTAL$(NC)"
	@sudo rm -f /etc/audit/rules.d/security-hardening.rules 2>/dev/null || true
	@sudo rm -f /etc/fail2ban/jail.local 2>/dev/null || true
	@sudo systemctl stop fail2ban auditd 2>/dev/null || true
	@echo "$(GREEN)✅ Limpeza concluída$(NC)"